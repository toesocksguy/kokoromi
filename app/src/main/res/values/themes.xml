<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — used by the Activity window before Compose renders.
         Keeping it minimal: Compose handles all the real theming. -->
    <style name="Theme.Kokoromi" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
